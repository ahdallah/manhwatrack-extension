{
  "manifest_version": 3,
  "name": "ManhwaTrack",
  "version": "1.0.1",
  "description": "Auto-track your manhwa & manhua reading progress across all sites. Syncs with your ManhwaTrack account.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ManhwaTrack"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.mangadex.org/*",
        "*://*.webtoons.com/*",
        "*://*.flixscans.org/*",
        "*://*.flixscans.to/*",
        "*://*.bato.to/*",
        "*://*.reaperscans.com/*",
        "*://*.asurascans.com/*",
        "*://*.asuracomic.net/*",
        "*://*.luminousscans.com/*",
        "*://*.manhuaus.com/*",
        "*://*.comick.io/*",
        "*://*.comick.fun/*",
        "*://*.toomics.com/*",
        "*://*.tapas.io/*",
        "*://*.tappytoon.com/*",
        "*://*.lezhin.com/*",
        "*://*.manta.net/*",
        "*://*.naver.com/*",
        "*://*.kakaopage.com/*",
        "*://*.roliascan.com/*",
        "*://*.manganato.com/*",
        "*://*.chapmanganato.to/*",
        "*://*.chapmanganato.to/*",
        "*://*.pickmeupgacha.com/*",
        "*://*.void-scans.com/*",
        "*://*.flamescans.org/*",
        "*://*.nightscans.net/*",
        "*://*.isekaiscan.com/*",
        "*://*.mangafire.to/*",
        "*://*.tcbscans.me/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://manhwatrack.com/*",
    "*://www.manhwatrack.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{a8f2e3b1-4c7d-4e9f-8a2b-1c3d5e7f9a0b}",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo"
        ],
        "optional": [
          "technicalAndInteraction"
        ]
      }
    }
  }
}